---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact Us — Veternity Beraksi"
  description="Get in touch with the Veternity Beraksi IT competition committee. Ask questions, submit feedback, or inquire about sponsorship opportunities."
>
  <ShaderBackground />
  <div class="halftone-overlay" aria-hidden="true"></div>

  <Header />

  <main id="main-content">
    <!-- Contact Hero Section -->
    <section class="contact-hero">
      <div class="ghost-label contact-ghost" aria-hidden="true">CONNECT</div>
      <div class="container relative z-10">
        <h1 class="contact-title">
          <span class="contact-title-line1">GET IN</span>
          <span class="contact-title-line2">TOUCH</span>
        </h1>
        <p class="contact-sub">
          Have an inquiry, feedback, or interest in partnership? Send us a message, and our team will get back to you shortly.
        </p>
      </div>
    </section>

    <!-- Content Split Layout -->
    <section class="contact-split-section">
      <div class="container contact-inner">
        
        <!-- Left Column: Form Card -->
        <div class="contact-form-col">
          <div class="form-card">
            <h3 class="form-card-title text-label">Send a Message</h3>
            
            <form class="contact-form" action="#" method="POST">
              <!-- Name Input -->
              <div class="form-group">
                <label for="name" class="form-label">Full Name</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="e.g. John Doe" required />
              </div>

              <!-- Email Input -->
              <div class="form-group">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="e.g. john@example.com" required />
              </div>

              <!-- Subject Input -->
              <div class="form-group">
                <label for="subject" class="form-label">Subject</label>
                <input type="text" id="subject" name="subject" class="form-input" placeholder="e.g. Partnership Inquiries" required />
              </div>

              <!-- Message Textarea -->
              <div class="form-group">
                <label for="message" class="form-label">Your Message</label>
                <textarea id="message" name="message" class="form-input form-textarea" placeholder="How can we help you?" rows="5" required></textarea>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn-primary form-submit">Send Message</button>
            </form>
          </div>
        </div>

        <!-- Right Column: Details & Connect Lines -->
        <div class="contact-details-col">
          <div class="details-box">
            
            <!-- Connection Line Decoration -->
            <div class="deco-connector" aria-hidden="true">
              <div class="deco-line"></div>
              <div class="deco-circle"></div>
            </div>

            <div class="details-item">
              <span class="details-label text-label">General Email</span>
              <p class="details-value">hello@veternityberaksi.com</p>
            </div>

            <div class="details-item">
              <span class="details-label text-label">Secretariat Address</span>
              <p class="details-value">
                Veternity IT Building, 5th Floor<br />
                Jl. Beraksi Raya No. 12<br />
                Jakarta, Indonesia
              </p>
            </div>

            <div class="details-item">
              <span class="details-label text-label">Social Media Handles</span>
              <div class="details-socials">
                <a href="#" class="social-tag sticker">Instagram</a>
                <a href="#" class="social-tag sticker sticker--indigo">YouTube</a>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .halftone-overlay {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(#11144c 20%, transparent 20%);
    background-size: 10px 10px;
    opacity: 0.05;
    pointer-events: none;
    z-index: -1;
  }

  :global(html) {
    scroll-padding-top: 72px;
  }

  /* Contact Hero */
  .contact-hero {
    position: relative;
    padding-top: clamp(4rem, 8vw, 6rem);
    padding-bottom: clamp(3rem, 6vw, 4.5rem);
    border-bottom: 2px dashed var(--color-navy);
    overflow: hidden;
  }

  .contact-ghost {
    position: absolute;
    top: 50%;
    right: -2rem;
    transform: translateY(-50%);
    font-size: clamp(6rem, 18vw, 12rem);
    line-height: 1;
    z-index: 0;
  }

  .contact-title {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .contact-title-line1 {
    font-size: clamp(3.5rem, 10vw, 8.5rem);
    color: var(--color-navy);
    transform: rotate(1deg);
    display: inline-block;
  }

  .contact-title-line2 {
    font-size: clamp(3.5rem, 10vw, 8.5rem);
    color: var(--color-indigo);
    transform: rotate(-1.5deg);
    margin-left: var(--space-4);
    display: inline-block;
    -webkit-text-stroke: 2px var(--color-navy);
    paint-order: stroke fill;
  }

  .contact-sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    line-height: 1.6;
    max-width: 38rem;
    color: var(--color-navy);
    opacity: 0.9;
  }

  /* Split layout section */
  .contact-split-section {
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 5vw, 4rem);
  }
  @media (min-width: 1024px) {
    .contact-inner {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  /* Form Column */
  .contact-form-col {
    flex: 1.3;
    width: 100%;
  }

  .form-card {
    border: 2px solid var(--color-navy);
    background: var(--color-white);
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
  }

  .form-card-title {
    font-size: 0.875rem;
    color: var(--color-indigo);
    margin-bottom: var(--space-6);
    border-bottom: 2px solid var(--color-navy);
    padding-bottom: var(--space-1);
    display: inline-block;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Form groups */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-navy);
  }

  /* Input fields per DESIGN.md:
     "Rectangular with sharp corners. Use a 2px bottom border that thickens on focus." */
  .form-input {
    border: none;
    border-bottom: 2px solid var(--color-navy);
    border-radius: 0;
    padding-block: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    background: transparent;
    color: var(--color-navy);
    width: 100%;
    transition: border-bottom-width 0.1s ease;
  }
  .form-input::placeholder {
    opacity: 0.4;
    color: var(--color-navy);
  }
  .form-input:focus {
    outline: none;
    border-bottom-width: 4px;
    border-bottom-color: var(--color-indigo);
  }

  .form-textarea {
    resize: vertical;
  }

  .form-submit {
    align-self: flex-start;
    padding: 0.75rem 2rem;
    font-size: 0.9375rem;
  }

  /* Details Column */
  .contact-details-col {
    flex: 0.9;
    width: 100%;
    position: relative;
  }

  .details-box {
    border: 2px solid var(--color-navy);
    background: var(--color-white);
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: relative;
  }

  /* Decorator connectors from DESIGN.md */
  .deco-connector {
    position: absolute;
    top: -2px;
    left: 40px;
    width: 2px;
    height: 40px;
    background: var(--color-navy);
    transform: translateY(-100%);
    display: none;
  }
  @media (min-width: 1024px) {
    .deco-connector {
      display: block;
    }
  }
  .deco-line {
    width: 100%;
    height: 100%;
  }
  .deco-circle {
    position: absolute;
    top: 0;
    left: -4px;
    width: 10px;
    height: 10px;
    background: var(--color-lime);
    border: 2px solid var(--color-navy);
    border-radius: 50%;
  }

  .details-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .details-label {
    font-size: 0.6875rem;
    color: var(--color-indigo);
    border-bottom: 1px solid var(--color-navy);
    padding-bottom: 2px;
    align-self: flex-start;
  }

  .details-value {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-navy);
  }

  .details-socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-1);
  }
  .social-tag {
    transform: rotate(-2deg);
    font-size: 0.8125rem;
  }
  .sticker--indigo {
    background-color: var(--color-indigo);
    color: var(--color-white);
  }
</style>
