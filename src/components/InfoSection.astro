---
// InfoSection.astro — Timeline (left) + Why Join benefits (right)
---

<section class="info-section" id="about">
  <!-- Ghost background label -->
  <div class="ghost-label info-ghost" aria-hidden="true">INFO HUB</div>

  <div class="container info-inner">

    <!-- LEFT: Event Timeline -->
    <div class="timeline-col">
      <h2 class="info-heading info-heading--dark">Event Timeline</h2>

      <div class="timeline">
        <!-- Item 1 -->
        <div class="timeline-item">
          <div class="timeline-dot timeline-dot--lime"></div>
          <div class="timeline-num">01</div>
          <div class="timeline-content">
            <h4 class="timeline-title">Registration Phase</h4>
            <p class="timeline-date">Oct 1 – 31, 2026</p>
            <p class="timeline-desc">Open registration for all participating teams across all tracks.</p>
          </div>
        </div>

        <!-- Item 2 (indented) -->
        <div class="timeline-item timeline-item--right">
          <div class="timeline-num">02</div>
          <div class="timeline-content">
            <h4 class="timeline-title">Technical Meeting</h4>
            <p class="timeline-date">Nov 5 – 10, 2026</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="timeline-item">
          <div class="timeline-dot timeline-dot--white"></div>
          <div class="timeline-num">03</div>
          <div class="timeline-content">
            <h4 class="timeline-title">Finalist Announcement</h4>
            <p class="timeline-date">Nov 15, 2026</p>
          </div>
        </div>

        <!-- Item 4 (indented) -->
        <div class="timeline-item timeline-item--right">
          <div class="timeline-num">04</div>
          <div class="timeline-content">
            <h4 class="timeline-title">Announcement of Winners</h4>
            <p class="timeline-date">Nov 25, 2026</p>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Why Join -->
    <div class="benefits-col" id="faq">
      <h2 class="info-heading info-heading--lime">Why You Should Join</h2>

      <div class="benefits-grid">
        <!-- Certificate -->
        <article class="benefit-card">
          <div class="benefit-graphic">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="15" y="20" width="70" height="60" fill="#c4f383" stroke="#11144c" stroke-width="3"/>
              <line x1="25" y1="40" x2="80" y2="40" stroke="#11144c" stroke-width="4"/>
              <line x1="25" y1="55" x2="70" y2="55" stroke="#11144c" stroke-width="4"/>
              <circle cx="75" cy="75" r="15" fill="#4f53a8" stroke="#11144c" stroke-width="3"/>
            </svg>
          </div>
          <h4 class="benefit-title">Certificate</h4>
          <p class="benefit-desc">Earn an officially recognized certificate to showcase your technical achievement.</p>
        </article>

        <!-- Connection -->
        <article class="benefit-card benefit-card--indigo">
          <div class="benefit-graphic benefit-graphic--white">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="35" cy="40" r="30" fill="#c4f383" stroke="#11144c" stroke-width="3"/>
              <circle cx="65" cy="60" r="30" fill="none" stroke="#11144c" stroke-width="3"/>
              <line x1="20" y1="50" x2="80" y2="50" stroke="#11144c" stroke-linecap="square" stroke-width="6"/>
            </svg>
          </div>
          <h4 class="benefit-title benefit-title--lime">Connection</h4>
          <p class="benefit-desc benefit-desc--light">Network with top developers, designers, and entrepreneurs across Indonesia.</p>
        </article>

        <!-- Improve Skills -->
        <article class="benefit-card benefit-card--wide">
          <div class="benefit-graphic">
            <svg viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <polygon points="30,80 170,20 150,10 180,10 180,40" fill="#c4f383" stroke="#11144c" stroke-width="4"/>
              <line x1="20" y1="90" x2="160" y2="30" stroke="#11144c" stroke-width="4" stroke-dasharray="10,10"/>
            </svg>
          </div>
          <h4 class="benefit-title">Improve Skills</h4>
          <p class="benefit-desc">Challenge your limits with real-world problems and measurable outcomes.</p>
        </article>
      </div>
    </div>

  </div>
</section>

<style>
  .info-section {
    position: relative;
    padding-block: clamp(4rem, 8vw, 6rem);
    overflow: hidden;
  }

  /* Ghost background label */
  .info-ghost {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: clamp(4rem, 14vw, 9.5rem);
    white-space: nowrap;
    z-index: 0;
  }

  /* Two-column layout */
  .info-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 5rem);
  }
  @media (min-width: 1024px) {
    .info-inner {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  /* Shared column basis */
  .timeline-col,
  .benefits-col {
    flex: 1;
  }

  /* Section headings */
  .info-heading {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    display: inline-block;
    padding: 0.375rem 1rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
    transform: rotate(-1deg);
  }
  .info-heading--dark {
    background: var(--color-navy);
    color: var(--color-white);
  }
  .info-heading--lime {
    background: var(--color-lime);
    color: var(--color-navy);
    border: 2px solid var(--color-navy);
    box-shadow: var(--shadow-md);
    transform: rotate(1deg);
  }

  /* ---- TIMELINE ---- */
  .timeline {
    position: relative;
    padding-left: clamp(2.5rem, 5vw, 4rem);
    border-left: 4px dashed var(--color-navy);
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 3.5rem);
  }

  .timeline-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }
  /* Alternating indented items */
  .timeline-item--right {
    align-self: flex-end;
    width: 80%;
    padding-right: var(--space-4);
  }

  /* Timeline dot */
  .timeline-dot {
    position: absolute;
    left: calc(-1 * clamp(2.5rem, 5vw, 4rem) - 16px);
    top: 1.25rem;
    width: 28px; height: 28px;
    border: 2px solid var(--color-navy);
    border-radius: 50%;
    z-index: 2;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .timeline-dot--lime  { background: var(--color-lime); }
  .timeline-dot--white { background: var(--color-white); }
  .timeline-item:hover .timeline-dot { transform: scale(1.25); }

  /* Timeline number */
  .timeline-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1;
    color: var(--color-indigo);
    text-shadow: 4px 4px 0 var(--color-navy);
    flex-shrink: 0;
    min-width: clamp(2.5rem, 5vw, 4rem);
  }

  .timeline-content { padding-top: 0.375rem; }

  .timeline-title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 2px solid var(--color-navy);
    display: inline-block;
    padding-bottom: 2px;
    transition: background 0.2s ease;
  }
  .timeline-item:hover .timeline-title { background: var(--color-lime); }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    margin-top: var(--space-2);
    background: var(--color-white);
    border: 1px solid var(--color-navy);
    padding: 0.125rem 0.5rem;
    display: inline-block;
    box-shadow: var(--shadow-sm);
  }

  .timeline-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    margin-top: var(--space-3);
    max-width: 26rem;
    opacity: 0.8;
    line-height: 1.6;
  }

  /* ---- BENEFITS ---- */
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;           /* mobile: single column */
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (min-width: 500px) {
    .benefits-grid { grid-template-columns: 1fr 1fr; } /* ≥500px: 2 columns */
  }

  .benefit-card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-navy);
    background: var(--color-white);
    padding: var(--space-6);
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease;
  }
  .benefit-card:hover { transform: translateY(-4px); }

  .benefit-card--indigo { background: var(--color-indigo); }

  /* Wide card: full-width on mobile, spans 2 cols when grid has 2 columns */
  .benefit-card--wide { grid-column: 1 / -1; }

  .benefit-graphic {
    height: 120px;
    margin-bottom: var(--space-5);
    border-bottom: 2px solid var(--color-navy);
    padding-bottom: var(--space-3);
  }
  .benefit-graphic--white {
    background: var(--color-white);
  }
  .benefit-graphic svg {
    width: 100%;
    height: 100%;
  }

  .benefit-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    margin-bottom: var(--space-2);
  }
  .benefit-title--lime { color: var(--color-lime); }

  .benefit-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-navy);
    opacity: 0.85;
  }
  .benefit-desc--light { color: var(--color-white); opacity: 0.9; }
</style>
