---
// Footer.astro — Site footer with halftone overlay
---

<footer class="site-footer" id="contact">
  <!-- Halftone overlay — purely decorative -->
  <div class="footer-halftone" aria-hidden="true"></div>

  <div class="container footer-inner">

    <!-- Logo block -->
    <div class="footer-logo">
      <img src="/logo.svg" alt="" class="footer-logo-img" aria-hidden="true" />
      <div class="footer-logo-text">
        <span class="footer-logo-1">VETERNITY</span>
        <span class="footer-logo-2">BERAKSI</span>
      </div>
    </div>

    <!-- Link columns -->
    <div class="footer-cols">

      <!-- Competition -->
      <div class="footer-col">
        <span class="footer-col-heading">Competition</span>
        <a href="#" class="footer-link">Veternity Beraksi IT Competition</a>
        <a href="#" class="footer-link">IT Competition 2026</a>
        <a href="/#tracks" class="footer-link">Competition Tracks</a>
      </div>

      <!-- Organizers -->
      <div class="footer-col">
        <span class="footer-col-heading">Organizers</span>
        <a href="#" class="footer-link">Veternity Beraksi</a>
        <a href="#" class="footer-link">Competition Committee</a>
      </div>

      <!-- Social Media -->
      <div class="footer-col">
        <span class="footer-col-heading">Social Media</span>

        <!-- Instagram -->
        <a href="https://instagram.com/veternity.verse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          veternity.verse
        </a>

        <!-- TikTok -->
        <a href="https://tiktok.com/@veternitu.verse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.02 1.59 4.23.85.97 2.05 1.64 3.32 1.93.01 1.34-.01 2.68-.01 4.02-1.58-.02-3.13-.57-4.42-1.5-.7-.49-1.28-1.14-1.72-1.89-.01 4.05 0 8.09-.01 12.14-.09 2.11-.84 4.19-2.21 5.79-1.51 1.77-3.79 2.82-6.12 2.9-2.31.14-4.66-.62-6.26-2.27A9.06 9.06 0 0 1 2 18.07a8.91 8.91 0 0 1 5.92-8.52c1.23-.42 2.56-.47 3.82-.21v4.19a4.84 4.84 0 0 0-3.32.96 4.96 4.96 0 0 0-1.8 3.52 4.9 4.9 0 0 0 3.33 5.12c1.55.51 3.35.08 4.45-.98.81-.74 1.25-1.83 1.26-2.92.01-5.18.01-10.36.01-15.54.01-3.23.01-6.46 0-9.69Z"/>
          </svg>
          veternitu.verse
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom strip -->
  <div class="footer-bottom">
    <span class="footer-copy">©2026 UPN Veteran Yogyakarta. All rights reserved.</span>
    <span class="footer-copy footer-copy--mono">Built with Astro · Deployed on Cloudflare Pages</span>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-white);
    border-top: 4px solid var(--color-navy);
    padding-top: clamp(3rem, 6vw, 4.5rem);
    overflow: hidden;
  }

  /* Halftone overlay */
  .footer-halftone {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--color-navy) 20%, transparent 20%);
    background-size: 10px 10px;
    opacity: 0.05;
    pointer-events: none;
  }

  /* Inner layout */
  .footer-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  /* Logo */
  .footer-logo {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1;
    text-transform: uppercase;
    transform: rotate(-2deg);
    flex-shrink: 0;
  }
  .footer-logo-img {
    height: 44px;
    width: 44px;
  }
  .footer-logo-text {
    display: flex;
    flex-direction: column;
  }
  .footer-logo-1 {
    background: var(--color-navy);
    color: var(--color-white);
    padding: 0.125rem 0.5rem;
  }
  .footer-logo-2 {
    background: var(--color-lime);
    color: var(--color-navy);
    padding: 0.125rem 0.5rem;
    margin-top: 3px;
  }

  /* Column group */
  .footer-cols {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2rem);
  }
  @media (min-width: 640px) {
    .footer-cols { flex-direction: row; gap: clamp(2rem, 5vw, 4rem); }
  }

  /* Individual column */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-col-heading {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    border-bottom: 2px solid var(--color-navy);
    padding-bottom: var(--space-1);
    margin-bottom: var(--space-2);
    display: inline-block;
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 1px 4px;
    transition: background 0.2s ease;
    display: inline-block;
  }
  .footer-link:hover {
    background: var(--color-lime);
    border: 1px solid var(--color-navy);
  }

  /* Social links */
  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 2px 4px;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .footer-social-link:hover {
    background: var(--color-lime);
    border-color: var(--color-navy);
  }

  /* Bottom strip */
  .footer-bottom {
    position: relative;
    z-index: 1;
    border-top: 2px solid var(--color-navy);
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    justify-content: space-between;
    align-items: flex-start;
  }
  @media (min-width: 640px) {
    .footer-bottom { flex-direction: row; align-items: center; }
  }
  @media (min-width: 1024px) {
    .footer-bottom { padding-inline: var(--space-16); }
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-navy);
    opacity: 0.7;
  }
  .footer-copy--mono {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
  }
</style>
