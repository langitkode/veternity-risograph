---
// ShaderBackground.astro
// Pixel-perfect port of the WebGL risograph paper-grain shader.
// Uses is:inline so Astro doesn't try to bundle/transform it.
// Fixed-position, z-index: -1, pointer-events: none → zero layout impact.
---

<div class="shader-wrap" aria-hidden="true">
  <canvas id="shader-canvas"></canvas>
</div>

<script is:inline>
(function () {
  const canvas = document.getElementById('shader-canvas');
  if (!canvas) return;

  // Keep the WebGL drawing-buffer in sync with the CSS-sized element.
  function syncSize() {
    const w = canvas.clientWidth  || window.innerWidth  || 1280;
    const h = canvas.clientHeight || window.innerHeight || 720;
    if (canvas.width !== w || canvas.height !== h) {
      canvas.width  = w;
      canvas.height = h;
    }
  }

  if (typeof ResizeObserver !== 'undefined') {
    new ResizeObserver(syncSize).observe(canvas);
  } else {
    window.addEventListener('resize', syncSize);
  }
  syncSize();

  const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
  if (!gl) return;

  /* ---- Vertex Shader ---- */
  const vs = `
    attribute vec2 a_position;
    varying vec2 v_texCoord;
    void main() {
      v_texCoord = a_position * 0.5 + 0.5;
      gl_Position = vec4(a_position, 0.0, 1.0);
    }
  `;

  /* ---- Fragment Shader ---- */
  /* Risograph paper texture:
     - Warm off-white base (matches --color-offwhite: #f2f1e8)
     - Subtle pseudo-random grain (no texture file = zero extra HTTP requests)
     - Fine halftone dot grid overlay
     - Smooth animated mask drift for organic feel                          */
  const fs = `
    precision highp float;
    varying vec2 v_texCoord;
    uniform float u_time;
    uniform vec2  u_resolution;

    float noise(vec2 p) {
      return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
    }

    void main() {
      vec2 uv = v_texCoord;

      // Warm off-white base — matches CSS --color-offwhite (#f2f1e8)
      vec3 color = vec3(0.949, 0.945, 0.910);

      // Grain: pixel-space noise keeps it crisp at any DPI
      float grain = noise(uv * u_resolution + u_time * 0.8);
      color -= grain * 0.035;

      // Halftone dot grid (2px cells)
      float dotSize = 2.0;
      vec2  grid    = floor(uv * u_resolution / dotSize);
      float dot     = step(0.55, noise(grid));

      // Animated organic mask — prevents static feel
      float mask = smoothstep(0.38, 0.52,
        length(uv - 0.5 + 0.12 * sin(u_time * 0.18)));

      // Blend halftone gently so it doesn't overpower content
      color = mix(color, color - 0.018, dot * (1.0 - mask));

      gl_FragColor = vec4(color, 1.0);
    }
  `;

  /* ---- Compile + link program ---- */
  function createShader(type, src) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    return s;
  }

  const prog = gl.createProgram();
  gl.attachShader(prog, createShader(gl.VERTEX_SHADER,   vs));
  gl.attachShader(prog, createShader(gl.FRAGMENT_SHADER, fs));
  gl.linkProgram(prog);
  gl.useProgram(prog);

  /* ---- Full-screen quad ---- */
  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(
    gl.ARRAY_BUFFER,
    new Float32Array([-1, -1,  1, -1,  -1, 1,  1, 1]),
    gl.STATIC_DRAW
  );
  const posLoc = gl.getAttribLocation(prog, 'a_position');
  gl.enableVertexAttribArray(posLoc);
  gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

  const uTime = gl.getUniformLocation(prog, 'u_time');
  const uRes  = gl.getUniformLocation(prog, 'u_resolution');

  /* ---- Render loop ---- */
  function render(t) {
    // Fallback sync when ResizeObserver unavailable
    if (typeof ResizeObserver === 'undefined') syncSize();

    gl.viewport(0, 0, canvas.width, canvas.height);
    if (uTime) gl.uniform1f(uTime, t * 0.001);
    if (uRes)  gl.uniform2f(uRes, canvas.width, canvas.height);
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    requestAnimationFrame(render);
  }
  render(0);
})();
</script>

<style>
  .shader-wrap {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    pointer-events: none;
  }

  .shader-wrap canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
